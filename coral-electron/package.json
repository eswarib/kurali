{
  "name": "coral-electron",
  "version": "0.4.0",
  "description": "Electron UI and tray for Coral app",
  "main": "main.js",
  "scripts": {
    "build:prod": "electron-builder build --dir --linux AppImage",
    "build:win:msi": "electron-builder build --win msi",
    "build:win:portable": "electron-builder --win portable",
    "build:win:nsis": "electron-builder --win nsis",
    "build:win": "electron-builder --win portable nsis"
  },
  "author": "Eswari M",
  "license": "MIT",
  "devDependencies": {
    "electron": "^38.0.0",
    "electron-builder": "^25.1.8",
    "jest": "^30.0.4",
    "mocha": "^11.7.1"
  },
  "build": {
    "appId": "com.coral.app",
    "productName": "Coral",
    "directories": {
      "output": "../build/Release"
    },
    "files": [
      "main.js",
      "renderer/**",
      "icons/**",
      "coral.png"
    ],
    "extraResources": [
      {
        "from": "../dist/win-resources",
        "to": ".",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "nsis", "arch": ["x64"] },
        { "target": "msi", "arch": ["x64"] }
      ],
      "icon": "coral.png"
    },
    "msi": {
      "oneClick": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Coral"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
